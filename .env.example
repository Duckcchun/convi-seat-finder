VITE_KAKAO_MAP_API_KEY=your-kakao-javascript-key
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENABLE_SUPABASE_REMOTE=true

PUBLIC_DATA_KEY=your-data-go-kr-service-key
KAKAO_REST_KEY=your-kakao-rest-api-key

# Optional seed overrides
# 기본값: 서울 25개 자치구 전부
# 커스텀 지역 예: SEED_TARGET_REGIONS=서울특별시 강남구,서울특별시 종로구
# SEED_TARGET_REGION=서울특별시 강남구
# SEED_NUM_OF_ROWS=80
# SEED_PAGE_NO=1
# SEED_BRANDS=CU,GS25,세븐일레븐,이마트24
# SEED_DELAY_MS=220
